DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=fan_hub
DB_PASSWORD=replace_me
DB_NAME=anna_bliver_fan_hub
JWT_SECRET=replace_with_a_long_random_value
PORT=5000
TRUST_PROXY=1
REQUEST_BODY_LIMIT=10mb
CORS_ORIGIN=http://localhost:3000

# Site defaults. Admin database settings override these values.
SITE_TITLE=小猪anna的秘密基地
SITE_LOGO_URL=/annapiggy-logo.png
SITE_FAVICON_URL=/favicon.ico
CREATOR_DISPLAY_NAME=小猪anna
BILIBILI_UID=
SITE_HOME_TITLE=欢迎来到小猪anna的秘密基地
SITE_HOME_SUBTITLE=
SITE_ICP_TEXT=
SITE_PUBLIC_SECURITY_TEXT=

# Point settlement. POINTS_ROOM_ID must be set before automatic settlement runs.
POINTS_ROOM_ID=
POINTS_START_AT=2026-01-01T00:00:00+08:00
POINTS_COIN_PER_POINT=100

# Optional outbound Bot WebSocket client.
BOT_WS_URL=
BOT_WS_TOKEN=

# Optional Bilibili API cookie for server-side public profile refresh only.
BILIBILI_COOKIE=

# Optional Aliyun captcha.
ALIYUN_ACCESS_KEY_ID=
ALIYUN_ACCESS_KEY_SECRET=
ALIYUN_CAPTCHA_SCENE_ID=
ALIYUN_CAPTCHA_PREFIX=

# Optional Tencent SES. Addresses and notification targets are deployment settings.
TENCENT_SECRET_ID=
TENCENT_SECRET_KEY=
SES_FROM_EMAIL=
SES_FROM_NAME=小猪anna的秘密基地
SES_TEMPLATE_ID=
SES_REDEMPTION_TEMPLATE_ID=
SES_REDEMPTION_TO_EMAIL=
SES_MARSHMALLOW_TEMPLATE_ID=
SES_MARSHMALLOW_TO_EMAIL=

# Required only by npm run seed:demo.
DEMO_ADMIN_PASSWORD=
